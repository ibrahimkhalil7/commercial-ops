# Example environment variables for commercial-ops
# Copy this file to .env and fill values for your environment.

# Django settings
SECRET_KEY=replace-me-with-a-secure-secret
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=

# Database (PostgreSQL recommended for production)
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=commercial_ops_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres-password
DATABASE_HOST=db
DATABASE_PORT=5432

# Optional: for local dev fallback use sqlite
# DATABASE_ENGINE=django.db.backends.sqlite3
# DATABASE_NAME=db.sqlite3

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4173
CORS_ALLOW_ALL_ORIGINS=False

# JWT / auth
PAGE_SIZE=20

# Celery (optional)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Optional: create a superuser at container startup
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=ChangeMePassw0rd!
SUPERUSER_FIRST_NAME=Admin
SUPERUSER_LAST_NAME=User
